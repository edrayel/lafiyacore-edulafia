# EduLafia Environment Variables
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Generate secrets: ./scripts/generate-secrets.sh --apply
# 3. Fill in external service keys (Termii, WhatsApp, etc.) as needed
#
# NEVER commit .env to version control!

# Application
APP_NAME=edulafia
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=<REPLACE_WITH_GENERATED_VALUE>

# Database
DATABASE_URL=postgresql+asyncpg://edulafia:<REPLACE_WITH_GENERATED_VALUE>@localhost:5433/edulafia
POSTGRES_USER=edulafia
POSTGRES_PASSWORD=<REPLACE_WITH_GENERATED_VALUE>
POSTGRES_DB=edulafia

# Redis
REDIS_URL=redis://localhost:6380/0
REDIS_PASSWORD=

# CouchDB (Sync - for offline-first PWA)
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=<REPLACE_WITH_GENERATED_VALUE>
COUCHDB_SECRET=<REPLACE_WITH_GENERATED_VALUE>

# JWT Authentication
# IMPORTANT: JWT_ALGORITHM must be HS256 (symmetric keys)
JWT_SECRET_KEY=<REPLACE_WITH_GENERATED_VALUE>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (32-byte hex key for AES-256-GCM database encryption)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# External Services (optional - fill in as needed)
TERMII_API_KEY=
TERMII_SENDER_ID=EduLafia
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=pk_test_
FLUTTERWAVE_SECRET_KEY=
REMITA_MERCHANT_ID=
REMITA_API_KEY=

# AWS (for file uploads)
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=edulafia-uploads-dev

# Frontend
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=EduLafia
