{
  "name": "edulafia",
  "version": "1.0.0",
  "private": true,
  "description": "EduLafia - Integrated school management and adolescent health surveillance platform",
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=@edulafia/backend",
    "dev:frontend": "turbo dev --filter=@edulafia/frontend",
    "build": "turbo build",
    "build:backend": "turbo build --filter=@edulafia/backend",
    "build:frontend": "turbo build --filter=@edulafia/frontend",
    "test": "turbo test",
    "test:backend": "turbo test --filter=@edulafia/backend",
    "test:frontend": "turbo test --filter=@edulafia/frontend",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "type-check": "turbo type-check",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
